{% extends 'base.html.twig' %}

{% block title %}Session{% endblock %}

{% block body %}
    <h1>Session</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ session.id }}</td>
            </tr>
            <tr>
                <th>Id_admin</th>
                <td>{{ session.idAdmin }}</td>
            </tr>
            <tr>
                <th>Token</th>
                <td>{{ session.token }}</td>
            </tr>
            <tr>
                <th>Expiration</th>
                <td>{{ session.expiration ? session.expiration|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Donnees</th>
                <td>{{ session.donnees ? session.donnees|json_encode : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_session_index') }}">back to list</a>

    <a href="{{ path('app_session_edit', {'id': session.id}) }}">edit</a>

    {{ include('session/_delete_form.html.twig') }}
{% endblock %}
