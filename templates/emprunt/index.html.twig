{% extends 'base.html.twig' %}

{% block title %}Emprunts{% endblock %}

{% block body %}
    <h1>Liste des Emprunts</h1>
    <div class="p-3 m-4">
        <table class="table">
            <thead class="table-warning bg-dark">
                <tr>
                    <th>Id</th>
                    <th>Id_livre</th>
                    <th>Id_copain</th>
                    <th>Date_emprunt</th>
                    <th>Date_retour</th>
                    <th>actions</th>
                </tr>
            </thead>
            <tbody>
            {% for emprunt in emprunts %}
                <tr>
                    <td>{{ emprunt.id }}</td>
                    <td>{{ emprunt.idLivre }}</td>
                    <td>{{ emprunt.idCopain }}</td>
                    <td>{{ emprunt.dateEmprunt ? emprunt.dateEmprunt|date('Y-m-d') : '' }}</td>
                    <td>{{ emprunt.dateRetour ? emprunt.dateRetour|date('Y-m-d') : '' }}</td>
                    <td>
                        <a href="{{ path('app_emprunt_show', {'id': emprunt.id}) }}">show</a>
                        <a href="{{ path('app_emprunt_edit', {'id': emprunt.id}) }}">edit</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-warning">Pas d'Enregistrements trouvés</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <a href="{{ path('app_emprunt_new') }}" class="btn btn-warning">Nouvel Emprunt</a>
    </div>
{% endblock %}
